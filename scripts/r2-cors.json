{
  "rules": [
    {
      "allowed": {
        "origins": [
          "https://cantmute.me",
          "https://www.cantmute.me",
          "http://localhost:8000",
          "http://localhost:5500",
          "http://127.0.0.1:8000",
          "http://127.0.0.1:5500"
        ],
        "methods": ["GET", "HEAD"],
        "headers": ["*"]
      },
      "exposeHeaders": ["Content-Length", "Content-Type", "Content-Range", "Accept-Ranges"],
      "maxAgeSeconds": 3600
    }
  ]
}
